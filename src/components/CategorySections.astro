---
import { getCollection } from 'astro:content';
import { statSync } from 'node:fs';
import { resolve } from 'node:path';

const categories = [
  {
    id: 'ai',
    title: 'AI',
    desc: 'AI Agent、RAG、Function Calling、大模型应用落地',
    href: '/ai/1-提示词工程/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10 10 10 0 0 0-10-10Z"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
  },
  {
    id: 'architecture',
    title: 'Architecture',
    desc: '分布式系统、架构设计、业务系统建模',
    href: '/architecture/distributed-transaction/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>`,
  },
  {
    id: 'ai-news',
    title: 'AI News',
    desc: '每日 AI 资讯、论文、产品动态',
    href: '/ai-news/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-4 0v-2a2 2 0 0 1 2-2h12"/><path d="M8 6h8"/><path d="M8 10h8"/><path d="M8 14h5"/></svg>`,
  },
  {
    id: 'ai-workflow',
    title: 'AI 工作流',
    desc: 'AI 辅助开发、工具链、效率提升',
    href: '/ai-workflow/3-omo-what-it-is-how-it-works-and-how-to-use-it/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  },
  {
    id: 'claw',
    title: 'Claw 专栏',
    desc: 'OpenClaw / ZeroClaw 设计与实现',
    href: '/claw/openclaw/1-nodejs-agent-revolution/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15l2 2 4-4"/></svg>`,
  },
  {
    id: 'java',
    title: '古法编程',
    desc: 'Java、算法、运维、网络等基础工程',
    href: '/java/01-core/1-java21-virtual-threads/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
  },
];

const allDocs = await getCollection('docs');

function parseDateFromFilename(id: string): Date | null {
  const match = id.match(/(\d{4}-\d{2}-\d{2})/);
  if (match) return new Date(match[1]);
  const numMatch = id.match(/\/(\d{1,2})-/);
  if (numMatch) {
    const year = 2025 + Math.min(parseInt(numMatch[1], 10), 12);
    return new Date(`${year}-01-01`);
  }
  return null;
}

function getDocDate(doc: typeof allDocs[number]): number {
  if (doc.data.date) {
    return new Date(doc.data.date).getTime();
  }
  if (doc.data.lastUpdated) {
    return new Date(doc.data.lastUpdated).getTime();
  }
  const parsed = parseDateFromFilename(doc.id);
  if (parsed) return parsed.getTime();
  try {
    const ext = doc.id.endsWith('.mdx') ? '.mdx' : '.md';
    const filePath = resolve(`src/content/docs/${doc.id}${ext}`);
    const stats = statSync(filePath);
    return stats.mtime.getTime();
  } catch {
    return 0;
  }
}

function getCategoryDocs(categoryId: string) {
  return allDocs
    .filter(doc => {
      const id = doc.id;
      if (!id || id.endsWith('index') || id.includes('_category_') || id === 'index.mdx') return false;
      if (categoryId === 'java') {
        return id.startsWith('java/') || id.startsWith('algorithms/') || id.startsWith('ops/') || id.startsWith('network/');
      }
      return id.startsWith(`${categoryId}/`);
    })
    .sort((a, b) => getDocDate(b) - getDocDate(a))
    .slice(0, 5);
}
---

<div class="category-sections">
  {categories.map((cat, i) => {
    const docs = getCategoryDocs(cat.id);
    return (
      <a href={cat.href} class="category-section-card" style={`animation-delay: ${i * 60}ms`}>
        <div class="category-section-header">
          <div class="category-section-icon" set:html={cat.icon} />
          <div class="category-section-content">
            <h3 class="category-section-title">{cat.title}</h3>
            <p class="category-section-desc">{cat.desc}</p>
          </div>
        </div>
        {docs.length > 0 && (
          <ul class="category-section-list">
            {docs.map(doc => {
              const href = `/${doc.id.replace(/\.mdx?$/, '').replace(/\/index$/, '/')}/`;
              return (
                <li class="category-section-item">
                  <a href={href} class="category-section-link" onclick="event.stopPropagation()">
                    {doc.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </a>
    );
  })}
</div>

<style>
  .category-sections {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: 1rem;
    margin: 2rem 0 1rem;
  }

  .category-section-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 12px;
    background: var(--sl-color-surface);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s ease, transform 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
    animation: cardFadeIn 0.4s ease-out both;
  }

  .category-section-card:hover {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-accent-low, rgba(212, 165, 90, 0.08));
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
  }

  .category-section-header {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    margin-bottom: 1rem;
  }

  .category-section-icon {
    flex-shrink: 0;
    color: var(--sl-color-accent);
    margin-top: 0.1rem;
  }

  .category-section-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .category-section-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--sl-color-white);
    margin: 0;
    line-height: 1.3;
  }

  .category-section-desc {
    font-size: 0.8rem;
    color: var(--sl-color-gray-2);
    margin: 0;
    line-height: 1.5;
  }

  .category-section-list {
    list-style: none;
    margin: 0;
    padding: 0.75rem 0 0;
    border-top: 1px solid var(--sl-color-gray-6);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .category-section-item {
    margin: 0;
    padding: 0;
  }

  .category-section-link {
    display: block;
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    padding: 0.3rem 0;
    line-height: 1.45;
    transition: color 0.2s ease, padding-left 0.2s ease;
    border-radius: 4px;
  }

  .category-section-link:hover {
    color: var(--sl-color-accent);
    padding-left: 0.35rem;
  }

  @keyframes cardFadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .category-section-card {
      animation: none;
    }
  }
</style>
