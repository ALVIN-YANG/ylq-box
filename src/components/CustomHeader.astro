---
import type { Props } from '@astrojs/starlight/props';
import SiteTitle from '@astrojs/starlight/components/SiteTitle.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';
import Search from '@astrojs/starlight/components/Search.astro';
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { label: 'AI', href: '/ai/function-call-agent/', match: '/ai/' },
  { label: 'Architecture', href: '/architecture/distributed-transaction/', match: '/architecture/' },
  { label: 'Java', href: '/java/01-core/1-java21-virtual-threads/', match: '/java/' },
  { label: 'AI News', href: '/ai-news/', match: '/ai-news/' },
  { label: 'Opencode', href: '/opencode/individual/1-intro-and-model-selection/', match: '/opencode/' },
  { label: 'Claw 专栏', href: '/claw/openclaw/1-nodejs-agent-revolution/', match: '/claw/' },
  { label: 'Model Arena', href: '/model-arena', match: '/model-arena' },
  { label: 'Ops', href: '/ops/k8s/1-k8s-overview/', match: '/ops/' },
  { label: 'Network', href: '/network/1-ipv4地址范围与作用/', match: '/network/' },
  { label: 'Blog', href: '/blog/2026-02-28-mola-intro/', match: '/blog/' },
  { label: '关于', href: '/about/', match: '/about/' },
];

const currentPath = Astro.url.pathname;

function isActive(match: string): boolean {
  if (match === '/') return currentPath === '/';
  return currentPath.startsWith(match);
}
---

<div class="header sl-flex">
  <div class="title-wrapper sl-flex">
    <SiteTitle {...Astro.props} />
  </div>
  <div class="sl-flex spacer"></div>
  <nav class="sl-flex nav-links">
    {navLinks.map(link => (
      <a href={link.href} class:list={[{ active: isActive(link.match) }]}>{link.label}</a>
    ))}
  </nav>
  <div class="sl-flex right-group-mobile md:sl-hidden">
    <ThemeToggle />
  </div>
  <div class="sl-hidden md:sl-flex right-group">
    <Search {...Astro.props} />
    <div class="sl-flex social-icons">
      <SocialIcons {...Astro.props} />
    </div>
    <ThemeToggle />
  </div>
</div>

<style>
  .header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .title-wrapper {
    overflow: hidden;
  }
  .right-group {
    gap: 1rem;
    align-items: center;
  }
  .social-icons {
    gap: 1rem;
    align-items: center;
  }

  /* ── Desktop Nav ── */
  .nav-links {
    gap: 0.1rem;
    align-items: center;
    display: none;
    flex-wrap: wrap;
    justify-content: center;
  }
  @media (min-width: 50rem) {
    .nav-links {
      display: flex;
    }
  }
  .nav-links a {
    text-decoration: none;
    color: var(--sl-color-gray-2);
    font-weight: 500;
    font-size: 0.8rem;
    padding: 0.2rem 0.4rem;
    border-radius: 6px;
    white-space: nowrap;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .nav-links a:hover {
    color: #1f2937;
    background-color: #f3f5f7;
  }
  .nav-links a.active {
    color: #1f2937;
    background-color: #eef2f6;
  }

  /* ── Mobile right group ── */
  .right-group-mobile {
    align-items: center;
    gap: 0.5rem;
  }
</style>
