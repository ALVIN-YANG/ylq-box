---
import type { Props } from '@astrojs/starlight/props';
import SiteTitle from '@astrojs/starlight/components/SiteTitle.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';
import Search from '@astrojs/starlight/components/Search.astro';

const navLinks = [
  { label: 'AI', href: '/ai/function-call-agent/', match: '/ai/' },
  { label: 'Architecture', href: '/architecture/distributed-transaction/', match: '/architecture/' },
  { label: 'Java', href: '/java/1-language/optional/', match: '/java/' },
  { label: 'AI News', href: '/ai-news/', match: '/ai-news/' },
  { label: 'Ops', href: '/ops/k8s/1-k8s-overview/', match: '/ops/' },
  { label: 'Network', href: '/network/1-ipv4地址范围与作用/', match: '/network/' },
  { label: 'Blog', href: '/blog/2026-02-28-mola-intro/', match: '/blog/' },
];

const currentPath = Astro.url.pathname;

function isActive(match: string): boolean {
  if (match === '/') return currentPath === '/';
  return currentPath.startsWith(match);
}
---

<div class="header sl-flex">
  <div class="title-wrapper sl-flex">
    <SiteTitle {...Astro.props} />
  </div>
  <div class="sl-flex spacer"></div>
  <nav class="sl-flex nav-links">
    {navLinks.map(link => (
      <a href={link.href} class:list={[{ active: isActive(link.match) }]}>{link.label}</a>
    ))}
  </nav>
  <div class="sl-hidden md:sl-flex right-group">
    <Search {...Astro.props} />
    <div class="sl-flex social-icons">
      <SocialIcons {...Astro.props} />
    </div>
  </div>

  {/* Mobile menu */}
  <input type="checkbox" id="mobile-menu-toggle" class="mobile-menu-checkbox" aria-label="Toggle menu" />
  <label for="mobile-menu-toggle" class="mobile-menu-btn md:sl-hidden">
    <span class="hamburger"></span>
  </label>
  <div class="mobile-overlay">
    <nav class="mobile-nav">
      {navLinks.map(link => (
        <a href={link.href} class:list={[{ active: isActive(link.match) }]}>{link.label}</a>
      ))}
    </nav>
  </div>
</div>

<style>
  .header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .title-wrapper {
    overflow: hidden;
  }
  .right-group {
    gap: 1rem;
    align-items: center;
  }
  .social-icons {
    gap: 1rem;
    align-items: center;
  }

  /* ── Desktop Nav ── */
  .nav-links {
    gap: 0.25rem;
    align-items: center;
    display: none;
  }
  @media (min-width: 50rem) {
    .nav-links {
      display: flex;
    }
  }
  .nav-links a {
    text-decoration: none;
    color: var(--sl-color-gray-2);
    font-weight: 500;
    font-size: 0.85rem;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .nav-links a:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }
  .nav-links a.active {
    color: var(--sl-color-accent);
    background-color: var(--sl-color-accent-low, rgba(107, 156, 247, 0.1));
  }

  /* ── Mobile Menu ── */
  .mobile-menu-checkbox {
    display: none;
  }
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    cursor: pointer;
    border-radius: 6px;
    transition: background-color 0.2s ease;
    z-index: 20;
  }
  @media (min-width: 50rem) {
    .mobile-menu-btn {
      display: none;
    }
  }
  .mobile-menu-btn:hover {
    background-color: var(--sl-color-gray-6);
  }
  .hamburger {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--sl-color-gray-2);
    border-radius: 1px;
    position: relative;
    transition: background-color 0.2s ease;
  }
  .hamburger::before,
  .hamburger::after {
    content: '';
    display: block;
    width: 18px;
    height: 2px;
    background: var(--sl-color-gray-2);
    border-radius: 1px;
    position: absolute;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }
  .hamburger::before { top: -6px; }
  .hamburger::after  { top: 6px; }

  .mobile-menu-checkbox:checked ~ .mobile-menu-btn .hamburger {
    background: transparent;
  }
  .mobile-menu-checkbox:checked ~ .mobile-menu-btn .hamburger::before {
    transform: translateY(6px) rotate(45deg);
    background: var(--sl-color-white);
  }
  .mobile-menu-checkbox:checked ~ .mobile-menu-btn .hamburger::after {
    transform: translateY(-6px) rotate(-45deg);
    background: var(--sl-color-white);
  }

  /* ── Overlay ── */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    top: var(--sl-nav-height);
    background: rgba(16, 19, 26, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: 15;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 3rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .mobile-menu-checkbox:checked ~ .mobile-overlay {
    opacity: 1;
    visibility: visible;
  }
  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: min(85vw, 20rem);
  }
  .mobile-nav a {
    display: block;
    text-decoration: none;
    color: var(--sl-color-gray-1);
    font-weight: 500;
    font-size: 1.05rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .mobile-nav a:hover {
    background-color: var(--sl-color-gray-6);
    color: var(--sl-color-white);
  }
  .mobile-nav a.active {
    color: var(--sl-color-accent);
    background-color: var(--sl-color-accent-low, rgba(107, 156, 247, 0.1));
  }
</style>
