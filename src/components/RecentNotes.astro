---
import { getCollection } from 'astro:content';
import { statSync } from 'node:fs';
import { resolve } from 'node:path';

const categoryLabels: Record<string, string> = {
  ai: 'AI',
  architecture: 'Architecture',
  'ai-news': 'AI News',
  java: 'Java',
  ops: 'Ops',
  network: 'Network',
  blog: 'Blog',
  claw: 'Claw 专栏',
  opencode: 'Opencode 专栏',
};

function getCategory(id: string): string {
  const seg = id.split('/')[0];
  return categoryLabels[seg] || seg;
}

function formatDate(date: Date | undefined): string {
  if (!date) return '';
  return new Intl.DateTimeFormat('zh-CN', { month: 'short', day: 'numeric' }).format(new Date(date));
}

const allDocs = await getCollection('docs');

const priorityPrefixes = ['opencode/', 'claw/', 'ai-workflow/', 'ai/', 'architecture/', 'ai-news/'];

function getPriority(id: string): number {
  for (let i = 0; i < priorityPrefixes.length; i++) {
    if (id.startsWith(priorityPrefixes[i])) return i;
  }
  return priorityPrefixes.length;
}

function getDocDate(doc: typeof allDocs[number]): number {
  if (doc.data.lastUpdated) {
    return new Date(doc.data.lastUpdated).getTime();
  }
  try {
    const filePath = resolve(`src/content/docs/${doc.id}.md`);
    const stats = statSync(filePath);
    return stats.mtime.getTime();
  } catch {
    return 0;
  }
}

const recentDocs = allDocs
  .filter(doc => {
    const id = doc.id;
    return id
      && !id.endsWith('index')
      && !id.includes('_category_')
      && id !== 'index.mdx'
      && !id.startsWith('guides/')
      && !id.startsWith('reference/');
  })
  .sort((a, b) => {
    const pa = getPriority(a.id);
    const pb = getPriority(b.id);
    if (pa !== pb) return pa - pb;
    return getDocDate(b) - getDocDate(a);
  })
  .slice(0, 6);
---

<div class="notes-grid">
  {recentDocs.map((doc, i) => {
    const href = `/${doc.id.replace(/\.mdx?$/, '').replace(/\/index$/, '/')}/`;
    const category = getCategory(doc.id);
    const date = formatDate(doc.data.lastUpdated);
    const desc = doc.data.description || '';
    return (
      <a href={href} class="note-card" style={`animation-delay: ${i * 60}ms`}>
        <div class="note-meta">
          <span class="note-tag">{category}</span>
          {date && <span class="note-date">{date}</span>}
        </div>
        <h3 class="note-title">{doc.data.title}</h3>
        {desc && <p class="note-desc">{desc}</p>}
      </a>
    );
  })}
</div>

<style>
  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .note-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 10px;
    background: var(--sl-color-surface);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s ease, transform 0.25s ease, background-color 0.25s ease;
    animation: cardFadeIn 0.4s ease-out both;
  }

  .note-card:hover {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-accent-low, rgba(212, 165, 90, 0.08));
    transform: translateY(-2px);
  }

  .note-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.75rem;
  }

  .note-tag {
    color: var(--sl-color-accent);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .note-date {
    color: var(--sl-color-gray-3);
  }

  .note-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--sl-color-white);
    margin: 0;
    line-height: 1.4;
  }

  .note-desc {
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    margin: 0;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @keyframes cardFadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .note-card {
      animation: none;
    }
  }
</style>
