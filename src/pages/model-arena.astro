---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import data from '../data/model-arena.json';

const domesticSections = [
  { key: 'general', label: '通用', description: '综合对话、推理、长上下文与产品完成度' },
  { key: 'code', label: '代码', description: '编码、Agent、工具调用与工程落地能力' },
  { key: 'tts', label: 'TTS', description: '语音合成自然度、情感表现与商用成熟度' },
  { key: 'asr', label: 'ASR', description: '语音识别准确率、实时性与行业适配' },
  { key: 'video', label: '视频生成', description: '镜头稳定性、动作表现与一致性' },
  { key: 'image', label: '图片生成', description: '中文提示词理解、审美质量与可控性' },
];

const arenaCards = [
  { key: 'text', title: '综合对话', badge: 'Text', items: data.arena.text, featured: true },
  { key: 'code', title: '代码 / Web 开发', badge: 'Code', items: data.arena.code, featured: false },
  { key: 'vision', title: '视觉理解', badge: 'Vision', items: data.arena.vision, featured: false },
];

const highlights = [
  { label: '国际 Arena 榜单', value: '3', note: 'Text / Code / Vision' },
  { label: '国内模型分区', value: `${domesticSections.length}`, note: '覆盖通用到多模态' },
  { label: 'API 价格样本', value: `${data.pricing.length}+`, note: '便于成本对比' },
  { label: '发布时间线', value: `${data.releases.length}`, note: '追踪模型演进' },
];
---

<StarlightPage frontmatter={{ title: 'Model Arena', description: 'AI 模型综合对比与国内榜单', template: 'splash' }} sidebar={[]}>
  <div class="arena-dashboard">
    <header class="hero-panel">
      <div class="hero-copy">
        <span class="eyebrow">AI Model Intelligence Hub</span>
        <h1>模型排名与选型看板</h1>
        <p class="hero-text">把国际 Arena、国内模型分区、API 定价和发布时间线放到同一页，方便你快速做模型选型、竞品观察和技术跟踪。</p>
        <p class="updated">数据更新：{data.updatedAt} · 国际 Arena 来源 <a href={data.sources.arena.url} target="_blank">{data.sources.arena.label}</a> · 时间线参考 <a href={data.sources.releases.url} target="_blank">{data.sources.releases.label}</a></p>
      </div>
      <div class="hero-stats">
        {highlights.map((item) => (
          <div class="stat-card">
            <div class="stat-value">{item.value}</div>
            <div class="stat-label">{item.label}</div>
            <div class="stat-note">{item.note}</div>
          </div>
        ))}
      </div>
    </header>

    <div class="tabs" id="tabs">
      <button class="tab active" data-target="arena">国际 Arena</button>
      <button class="tab" data-target="domestic">国内模型</button>
      <button class="tab" data-target="pricing">API 定价</button>
      <button class="tab" data-target="timeline">发布时间线</button>
    </div>

    <section class="panel active" id="arena">
      <div class="section-head">
        <div>
          <h2>国际 Arena 榜单</h2>
          <p>保留国际主流评测口径，适合看当前头部模型在对话、代码和视觉理解上的整体位置。</p>
        </div>
        <a class="source-link" href={data.sources.arena.url} target="_blank">查看数据来源</a>
      </div>

      <div class="card-grid arena-grid">
        {arenaCards.map((card) => (
          <div class:list={["card", { "featured-card": card.featured }]}>
            <div class="card-title-row">
              <h3>{card.title}</h3>
              <span class="badge">{card.badge}</span>
            </div>
            <div class="card-tools">
              <a class="mini-source-link" href={data.sources.arena.url} target="_blank">来源</a>
            </div>
            <div class="table-scroll">
              <table>
                <thead><tr><th>#</th><th>模型</th><th>Rating</th><th>组织</th><th>投票</th></tr></thead>
                <tbody>
                  {card.items.map((m, i) => (
                    <tr>
                      <td class="rank">{i + 1}</td>
                      <td class="model-name">{m.name}</td>
                      <td class="num">{m.rating.toFixed(1)}</td>
                      <td class="org">{m.org}</td>
                      <td class="num">{m.votes.toLocaleString()}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="panel" id="domestic">
      <div class="section-head">
        <div>
          <h2>国内模型分区榜单</h2>
          <p>{data.domestic.note}</p>
        </div>
        <div class="section-head-side">
          <div class="section-meta">更新于 {data.domestic.updatedAt}</div>
          <a class="source-link" href={data.sources.domestic.url} target="_blank">查看总来源</a>
        </div>
      </div>

      <div class="category-nav">
        {domesticSections.map((section) => (
          <a href={`#domestic-${section.key}`} class="category-chip">{section.label}</a>
        ))}
      </div>

      <div class="domestic-grid">
        {domesticSections.map((section) => (
          <article class="card category-card" id={`domestic-${section.key}`}>
            <div class="category-head">
              <div>
                <h3>{section.label}</h3>
                <p>{section.description}</p>
              </div>
              <span class="badge soft">Top 5</span>
            </div>

            <div class="card-tools">
              <a class="mini-source-link" href={data.domestic.categories[section.key].source.url} target="_blank">{data.domestic.categories[section.key].source.label}</a>
            </div>

            <div class="domestic-list">
              {data.domestic.categories[section.key].items.map((item) => (
                <div class="domestic-item">
                  <div class="domestic-rank">#{item.rank}</div>
                  <div class="domestic-main">
                    <div class="domestic-topline">
                      <strong>{item.model}</strong>
                      <span>{item.org}</span>
                    </div>
                    <div class="domestic-strengths">{item.strengths}</div>
                    <div class="domestic-benchmark">{item.benchmark}</div>
                  </div>
                  <div class="score-pill">{item.score}</div>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="panel" id="pricing">
      <div class="section-head">
        <div>
          <h2>API 定价对比</h2>
          <p>统一按每百万 tokens 展示，方便快速看输入、输出与上下文成本结构。</p>
        </div>
        <a class="source-link" href={data.sources.pricing.url} target="_blank">查看数据来源</a>
      </div>
      <div class="card full-width">
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>模型</th>
                <th>提供商</th>
                <th>输入</th>
                <th>输出</th>
                <th>上下文</th>
                <th>最大输出</th>
              </tr>
            </thead>
            <tbody>
              {data.pricing.map((p) => (
                <tr>
                  <td class="model-name">{p.model}</td>
                  <td class="org">{p.provider}</td>
                  <td class="num price">${p.input.toFixed(2)}</td>
                  <td class="num price">${p.output.toFixed(2)}</td>
                  <td class="num">{p.context}</td>
                  <td class="num">{p.maxOutput}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="panel" id="timeline">
      <div class="section-head">
        <div>
          <h2>模型发布时间线</h2>
          <p>按时间回看模型迭代节奏，判断各厂商当前重点押注方向。</p>
        </div>
        <a class="source-link" href={data.sources.releases.url} target="_blank">查看数据来源</a>
      </div>
      <div class="card full-width">
        <div class="timeline-list">
          {data.releases.map((r) => (
            <div class="timeline-item">
              <div class="tl-date">{r.date}</div>
              <div class="tl-dot"></div>
              <div class="tl-content">
                <div class="tl-header">
                  <span class="tl-model">{r.model}</span>
                  <span class="tl-provider">{r.provider}</span>
                  {r.type && <span class="tl-type">{r.type}</span>}
                </div>
                <div class="tl-highlights">{r.highlights}</div>
                {r.features && r.features.length > 0 && (
                  <ul class="tl-features">
                    {r.features.map((f) => <li>{f}</li>)}
                  </ul>
                )}
                {r.url && <a class="tl-link" href={r.url} target="_blank">View Announcement</a>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    document.querySelectorAll('.tab').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.tab').forEach(function(b) { b.classList.remove('active'); });
        document.querySelectorAll('.panel').forEach(function(p) { p.classList.remove('active'); });
        btn.classList.add('active');
        var target = btn.getAttribute('data-target');
        if (target) document.getElementById(target).classList.add('active');
      });
    });
  </script>
</StarlightPage>

<style>
  .arena-dashboard {
    --bg-card: rgba(255, 255, 255, 0.96);
    --text-main: var(--sl-color-white, #0f172a);
    --text-dim: var(--sl-color-gray-3, #64748b);
    --border: var(--sl-color-gray-6, #e2e8f0);
    --accent: var(--sl-color-accent, #4b5f7c);
    --accent-strong: var(--sl-color-accent-high, #334155);
    --accent-low: var(--sl-color-accent-low, #f1f5f9);
    --mono: var(--sl-font-mono, 'JetBrains Mono', monospace);
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 0 3rem;
  }

  .hero-panel {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 1.25rem;
    margin: 0 0 1.5rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 10px 24px rgba(15, 23, 42, 0.03);
  }

  .eyebrow {
    display: inline-flex;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: #f3f5f7;
    color: var(--accent-strong);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    margin: 0.8rem 0 0.8rem;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.08;
    color: #0f172a;
    letter-spacing: -0.04em;
  }

  .hero-text {
    max-width: 46rem;
    margin: 0;
    color: #334155;
    font-size: 1rem;
    line-height: 1.8;
  }

  .updated {
    margin-top: 0.8rem;
    color: var(--text-dim);
    font-size: 0.84rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem;
  }

  .stat-card {
    padding: 1rem;
    border-radius: 14px;
    border: 1px solid #e7ebf0;
    background: rgba(249, 250, 251, 0.94);
    box-shadow: none;
  }

  .stat-value {
    font-size: 1.7rem;
    font-weight: 700;
    color: #1f2937;
    line-height: 1;
  }

  .stat-label {
    margin-top: 0.35rem;
    color: var(--text-main);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .stat-note {
    margin-top: 0.2rem;
    color: var(--text-dim);
    font-size: 0.76rem;
    line-height: 1.5;
  }

  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-bottom: 1.25rem;
  }

  .tab {
    all: unset;
    padding: 0.72rem 1rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.88);
    color: var(--text-dim);
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.18s ease;
  }

  .tab:hover {
    color: #334155;
    border-color: #d6dde6;
    background: #f6f8fa;
  }

  .tab.active {
    color: #1f2937;
    background: #eef2f6;
    border-color: #d8e0ea;
    box-shadow: none;
  }

  .panel { display: none; }
  .panel.active { display: block; }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-head-side {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.45rem;
  }

  .section-head h2 {
    margin: 0;
    color: #111827;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .section-head p,
  .section-meta {
    margin: 0.35rem 0 0;
    color: var(--text-dim);
    font-size: 0.88rem;
    line-height: 1.7;
  }

  .source-link,
  .mini-source-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #526276;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .source-link:hover,
  .mini-source-link:hover {
    text-decoration: underline;
  }

  .card-grid,
  .domestic-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .arena-grid {
    grid-template-columns: 1fr;
  }

  @media (min-width: 960px) {
    .arena-grid {
      grid-template-columns: 1.2fr 1fr 1fr;
    }
  }

  @media (min-width: 900px) {
    .domestic-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.15rem;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 8px 20px rgba(15, 23, 42, 0.03);
  }

  .featured-card {
    background: rgba(255, 255, 255, 0.98);
  }

  .full-width { width: 100%; }

  .card-title-row,
  .category-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.8rem;
    margin-bottom: 0.9rem;
  }

  .card-tools {
    margin: -0.3rem 0 0.75rem;
  }

  .card-title-row h3,
  .category-head h3 {
    margin: 0;
    font-size: 1rem;
    color: #0f172a;
    font-weight: 700;
  }

  .category-head p {
    margin: 0.3rem 0 0;
    color: var(--text-dim);
    font-size: 0.82rem;
    line-height: 1.65;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.5rem;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: #f3f5f7;
    color: #526276;
    font-size: 0.67rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .badge.soft {
    background: #f5f7f9;
    color: #5f6b7d;
  }

  .category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 1rem;
  }

  .category-chip {
    display: inline-flex;
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    border: 1px solid #e1e6ec;
    background: rgba(248, 249, 251, 0.98);
    color: #526276;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .category-chip:hover {
    background: #f2f5f7;
  }

  .domestic-list {
    display: grid;
    gap: 0.75rem;
  }

  .domestic-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.9rem;
    align-items: start;
    padding: 0.9rem;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.92);
  }

  .domestic-rank {
    min-width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: #f3f5f7;
    color: #334155;
    font-weight: 800;
    font-family: var(--mono);
  }

  .domestic-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: baseline;
  }

  .domestic-topline strong {
    color: #0f172a;
    font-size: 0.98rem;
  }

  .domestic-topline span,
  .domestic-strengths,
  .domestic-benchmark {
    color: var(--text-dim);
    font-size: 0.8rem;
    line-height: 1.6;
  }

  .domestic-strengths {
    margin-top: 0.25rem;
    color: #334155;
  }

  .domestic-benchmark {
    margin-top: 0.18rem;
    font-family: var(--mono);
    font-size: 0.74rem;
  }

  .score-pill {
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    background: #1f2937;
    color: white;
    font-size: 0.84rem;
    font-weight: 800;
    font-family: var(--mono);
  }

  .table-scroll { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.84rem;
  }

  thead th {
    text-align: left;
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #64748b;
    padding: 0.7rem 0.65rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  tbody td {
    padding: 0.65rem;
    border-bottom: 1px solid rgba(226, 232, 240, 0.9);
    vertical-align: middle;
  }

  tbody tr:hover {
    background: #f8fafb;
  }

  .rank {
    width: 2.5rem;
    text-align: center;
    color: #475569;
    font-weight: 800;
    font-family: var(--mono);
  }

  .model-name {
    font-family: var(--mono);
    font-size: 0.79rem;
    color: #0f172a;
    white-space: nowrap;
  }

  .num {
    text-align: right;
    font-variant-numeric: tabular-nums;
    font-family: var(--mono);
    font-size: 0.79rem;
    color: #1e293b;
  }

  .org {
    color: #64748b;
    font-size: 0.79rem;
  }

  .price {
    font-weight: 700;
    color: #334155;
  }

  .timeline-list {
    position: relative;
    padding-left: 1rem;
  }

  .timeline-list::before {
    content: '';
    position: absolute;
    left: 4.5rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, #e1e6ec, #eef2f5);
  }

  .timeline-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.7rem 0;
    position: relative;
  }

  .tl-date {
    width: 5.5rem;
    flex-shrink: 0;
    font-family: var(--mono);
    font-size: 0.74rem;
    color: #64748b;
    text-align: right;
    padding-top: 0.15rem;
  }

  .tl-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #334155;
    flex-shrink: 0;
    margin-top: 0.35rem;
    position: relative;
    z-index: 1;
    box-shadow: 0 0 0 4px rgba(245, 247, 250, 0.98);
  }

  .tl-content { flex: 1; min-width: 0; }

  .tl-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tl-model {
    font-weight: 700;
    font-size: 0.92rem;
    color: #0f172a;
  }

  .tl-provider,
  .tl-highlights,
  .tl-features {
    color: #64748b;
  }

  .tl-provider {
    font-size: 0.76rem;
  }

  .tl-type {
    font-size: 0.64rem;
    font-weight: 800;
    padding: 0.12rem 0.42rem;
    border-radius: 999px;
    background: #f3f5f7;
    color: #526276;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .tl-highlights {
    font-size: 0.82rem;
    margin-top: 0.2rem;
    line-height: 1.65;
  }

  .tl-features {
    margin: 0.35rem 0 0;
    padding-left: 1.1rem;
    list-style: disc;
    font-size: 0.76rem;
    line-height: 1.65;
  }

  .tl-features li { margin: 0; }

  .tl-link {
    display: inline-block;
    margin-top: 0.35rem;
    font-size: 0.74rem;
    color: var(--accent-strong);
    text-decoration: none;
  }

  .tl-link:hover { text-decoration: underline; }

  @media (max-width: 960px) {
    .hero-panel {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .hero-stats {
      grid-template-columns: 1fr 1fr;
    }

    .section-head,
    .category-head,
    .section-head-side {
      flex-direction: column;
      align-items: flex-start;
    }

    .domestic-item {
      grid-template-columns: 1fr;
    }

    .score-pill {
      justify-self: start;
    }
  }

  @media (max-width: 600px) {
    .arena-dashboard { padding: 0 0 2rem; }
    .hero-panel,
    .card { padding: 0.95rem; }
    .hero-stats { grid-template-columns: 1fr; }
